{
  "manifest_version": 3,
  "name": "web-mianshiya",
  "version": "0.1.0",
  "description": "从面试鸭题库页面抓取题目，并上传到 Victor AI 题库。",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.mianshiya.com/*",
    "https://api.mianshiya.com/*",
    "http://localhost:5173/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:5173/*",
    "http://127.0.0.1:8080/*"
  ],
  "action": {
    "default_title": "web-mianshiya",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mianshiya.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
