{
  "manifest_version": 3,
  "name": "牛客题库导入 Victor",
  "version": "0.1.0",
  "description": "从牛客网面试题库抓取题目，并上传到 Victor AI 题库。",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8080/*", "http://127.0.0.1:8080/*"],
  "action": {
    "default_title": "牛客题库导入",
    "default_popup": "popup.html"
  }
}
